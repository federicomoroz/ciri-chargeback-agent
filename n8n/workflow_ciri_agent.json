        "path": "chargeback-agent",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "7fdde72c-ede9-45ab-b82c-ed3d9f117114",
      "name": "Webhook — Entrada",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        1472,
        2272
      ],
      "webhookId": "ciri-chargeback-agent"
    },
    {
      "parameters": {
        "jsCode": "// Extraer y validar el body del webhook\nconst body = $input.first().json.body || {};\n\nconst txnId      = (body.transaction_id || '').trim();\nconst motivo     = (body.motivo || '').trim();\nconst clienteVip = Boolean(body.cliente_vip);\n\n// Validar formato TXN-XXXXX (exactamente 5 dígitos)\nif (!txnId.match(/^TXN-\\d{5}$/)) {\n  throw new Error(\n    `Formato de transaction_id inválido: \"${txnId}\". ` +\n    `Se esperaba TXN-XXXXX (ej: TXN-00051).`\n  );\n}\n\nreturn [{ json: { transaction_id: txnId, motivo, cliente_vip: clienteVip } }];"
      },
      "id": "da072941-6f48-40b1-942d-53b8d2fc0dab",
      "name": "Validar Formato TXN",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1696,
        2272
      ]
    },
