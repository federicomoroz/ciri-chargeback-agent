        "bodyParameters": {
          "parameters": [
            {
              "name": "resolution",
              "value": "={{ $json }}"
            },
            {
              "name": "full_context",
              "value": "={{ { transaction: $('Compilar Contexto').item.json.tx_data, motivo: $('Compilar Contexto').item.json.motivo, policies: $('Compilar Contexto').item.json.policies, similar_cases: $('Compilar Contexto').item.json.similar_cases } }}"
            }
          ]
        },
        "options": {}
      },
      "id": "9214e920-e3b0-4adf-b81e-38c08a1cca7c",
      "name": "Juez de Calidad",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        3984,
        2272
      ]
    },
    {
      "parameters": {
        "jsCode": "// Construir el payload exacto que espera POST /api/reports/html (ReportRequest)\nconst ctx        = $('Compilar Contexto').item.json;\nconst resolution = $('Sintetizar Resolución').item.json;\nconst judge      = $input.first().json;  // output de Juez de Calidad\n\nreturn [{\n  json: {\n    // Campos de ReportRequest\n    transaction:         ctx.tx_data,\n    resolution:          resolution,\n    judge_evaluation:    judge,\n    agent_analysis:      ctx.agent_analysis,\n    merchant_risk:       ctx.merchant_risk,\n    client_profile:      ctx.client_history,\n    logs:                ctx.logs,\n    policies_evaluated:  ctx.policies,\n    similar_cases:       ctx.similar_cases,\n    hitl_decision:       null,\n    cache_hit:           false,\n    guardrail_warnings:  resolution.guardrail_warnings || [],\n  }\n}];"
      },
      "id": "b5e2dccf-6644-4a69-b307-6d429687b963",
      "name": "Preparar Informe",
