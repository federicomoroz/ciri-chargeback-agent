      "id": "28182696-8b26-4d50-a7e1-2483a095cb4e",
      "name": "Verificar SLA",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        3280,
        2272
      ]
    },
    {
      "parameters": {
        "jsCode": "// Fusionar todos los datos recopilados en un objeto unificado\nconst input      = $('Validar Formato TXN').item.json;\nconst txn        = $('Obtener Transacción').item.json;\nconst logsData   = $('Obtener Logs').item.json;\nconst policies   = $('Buscar Políticas').item.json;\nconst cases      = $('Buscar Casos Similares').item.json;\nconst merchant   = $('Riesgo del Comercio').item.json;\nconst client     = $('Historial del Cliente').item.json;\nconst sla        = $('Verificar SLA').item.json;\n\nconst slaStatus = sla.within_sla\n  ? `dentro de SLA (${sla.days_elapsed}d / ${sla.sla_limit_days}d)`\n  : `FUERA de SLA (${sla.days_elapsed}d / ${sla.sla_limit_days}d)`;\n\nconst agentAnalysis = [\n  `Caso ${input.transaction_id}: ${txn.merchant}, USD ${txn.amount_usd},`,\n  `canal ${txn.channel}, país ${txn.country}, score fraude ${txn.fraud_score}.`,\n  `Motivo: ${input.motivo || 'no especificado'}.`,\n  `SLA: ${slaStatus}.`,\n  `Cliente VIP: ${input.cliente_vip ? 'sí' : 'no'}.`,\n  `Políticas encontradas: ${(policies.results || []).length}.`,\n  `Casos similares: ${(cases.results || []).length}.`,\n].join(' ');\n\nreturn [{\n  json: {\n    transaction_id:  input.transaction_id,\n    motivo:          input.motivo,\n    cliente_vip:     input.cliente_vip,\n    tx_data:         txn,\n    logs:            logsData.logs || [],\n    policies:        policies.results || [],\n    similar_cases:   cases.results || [],\n    merchant_risk:   merchant,\n    client_history:  client,\n    sla:             sla,\n    agent_analysis:  agentAnalysis,\n  }\n}];"
      },
      "id": "1297b168-fa5f-4ca1-8640-bd4db026da49",
      "name": "Compilar Contexto",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3536,
        2272
      ]
    },
